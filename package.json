{
  "name": "mimir-agent",
  "version": "0.1.0",
  "description": "Multi-agent self-improving system with shared experiential memory and parallel agent execution",
  "type": "module",
  "bin": {
    "mimir": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch ./src/index.ts",
    "start": "node ./dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "express": "^5.2.1",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "mcp",
    "multi-agent",
    "ai",
    "local-first",
    "experiential-learning",
    "mimir"
  ],
  "author": "",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  }
